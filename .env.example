# Supabase (optional — without these, Jaydee runs in local-only mode)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === SETUP INSTRUCTIONS ===
# 1. In Supabase Dashboard > Authentication:
#    - Enable "Anonymous sign-ins" (for guest mode)
#    - Optionally enable Email provider
#
# 2. Run the SQL below in the SQL Editor (one by one or as a script):
#
# 3. In Storage > Create bucket named "audio_assets" (public or private, policies below handle access)
#
# 4. Copy this .env.example to .env and fill real values.
#    For production deploy (Vercel/Netlify/etc): set the two VITE_ vars in the hosting env.

# --- projects table ---
create table if not exists projects (
  id uuid primary key,
  user_id uuid not null references auth.users(id) on delete cascade,
  name text not null,
  data jsonb not null,
  updated_at timestamptz default now()
);

alter table projects enable row level security;

create policy "Users manage own projects"
  on projects
  for all
  using (auth.uid() = user_id)
  with check (auth.uid() = user_id);

# --- Storage bucket + policies for audio_assets ---
-- (run after creating the bucket in UI if needed)
insert into storage.buckets (id, name, public)
values ('audio_assets', 'audio_assets', false)
on conflict (id) do nothing;

alter table storage.objects enable row level security;

-- Allow users to upload their own files (folder = user_id)
create policy "Users can upload own audio"
  on storage.objects
  for insert
  with check (
    bucket_id = 'audio_assets' and
    auth.uid()::text = (storage.foldername(name))[1]
  );

-- Allow users to download / select their own files
create policy "Users can download own audio"
  on storage.objects
  for select
  using (
    bucket_id = 'audio_assets' and
    auth.uid()::text = (storage.foldername(name))[1]
  );

-- (Optional) allow users to update/delete their files
create policy "Users can update own audio"
  on storage.objects
  for update
  using (bucket_id = 'audio_assets' and auth.uid()::text = (storage.foldername(name))[1]);

create policy "Users can delete own audio"
  on storage.objects
  for delete
  using (bucket_id = 'audio_assets' and auth.uid()::text = (storage.foldername(name))[1]);

# Note: Realtime uses broadcast channels (no extra table needed). The app filters by userId client-side.